# Jira Cloud: dominio (sin https), email y API token
# Crea el token en: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_DOMAIN=tu-empresa.atlassian.net
JIRA_EMAIL=tu-email@empresa.com
JIRA_API_TOKEN=tu_api_token_aqui

# Opcional: ID del campo Story Points en tu Jira (por defecto 10016)
# JIRA_STORY_POINTS_FIELD=customfield_10016

# Puerto del backend
PORT=3001
